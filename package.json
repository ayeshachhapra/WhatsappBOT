{
  "name": "watracker",
  "version": "1.0.0",
  "description": "Single-user WhatsApp group tracker bot with AI extraction, chat, and scheduled follow-ups",
  "main": "dist/index.js",
  "scripts": {
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "mongodb": "^6.12.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
